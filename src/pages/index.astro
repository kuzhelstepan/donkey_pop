---
import BaseLayout from '../layouts/BaseLayout.astro';
import donkey from '../../donkey.png';
import popsicle from '../../popsicle.jpg';
---

<BaseLayout title="School Fair Popsicles" description="A student-run ice popsicle stand for the school fair.">
  <main class="site-shell">
    <header class="topbar">
      <p class="eyebrow">School Fair Treats</p>
      <h1>Cool popsicles for the fair</h1>
      <p class="topbar-copy">
      Donkey treats, the best refreshment at St.Gregs
      </p>
    </header>

    <section class="hero" aria-labelledby="logo-title">
      <div class="hero-card">
        <p class="section-label" id="logo-title">Logo space</p>
        <img src={donkey.src} alt="Logo for the school fair popsicle stand" class="hero-logo" />
      </div>
    </section>

    <section class="intro-card" aria-labelledby="intro-title">
      <h2 id="intro-title">Intro paragraph</h2>
      <p>
        Welcome to Donkey treats at the school fair. We provide refreshing flavors for a cheap price for students at St.Gregs 
      </p>
    </section>

    <section class="carousel-section" aria-labelledby="carousel-title">
      <div class="section-heading">
        <div>
          <p class="section-label">Carousel</p>
          <h2 id="carousel-title">Featured popsicles</h2>
        </div>
        <p>Swipe or scroll to browse the slides.</p>
      </div>

      <div class="carousel-actions" aria-label="Slide shortcuts">
        <a href="#slide-1">1</a>
        <a href="#slide-2">2</a>
      </div>

      <div class="carousel-track" tabindex="0" aria-label="Popsicle carousel">
        <article class="slide" id="slide-1">
          <div class="slide-media">
            <img src={popsicle.src} alt="Popsicle displayed for sale" />
          </div>
          <div class="slide-copy">
            <h3>Fresh popsicle box</h3>
            <p class="price">$0.5 or $1 for 2 popsicles</p>
            <p>
              The best popsicle in my opinion it is cold, just right for a hot day and it has low calories.
            </p>
          </div>
        </article>

        <article class="slide" id="slide-2">
          <div class="slide-media slide-placeholder" aria-hidden="true">
            <span>Picture space</span>
          </div>
          <div class="slide-copy">
            <h3>Popsicle story</h3>
            <p class="placeholder-note">Add a picture here and write 3-5 sentences about the popsicle.</p>
            <p>
              Cool down with the refreshing, icy blast of our delicious fruit popsicles. Perfect for a sunny day, every bite is packed with bold, natural flavor that brings a smile to your face.
            </p>
          </div>
        </article>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="footer-card">
      <p class="section-label">Team</p>
      <h2>Meet the team</h2>
      <p>Add your team details, roles, or a short thank-you message in this footer area.</p>
    </div>
  </footer>
</BaseLayout>